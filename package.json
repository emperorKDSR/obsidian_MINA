{
  "name": "mina_v2",
  "version": "1.3.1",
  "description": "Mina: Quickly capture thoughts and tasks to a file.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
