  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "builtin-modules": "5.1.0",
    "esbuild": "0.28.0",
    "moment": "^2.30.1",
    "obsidian": "^1.12.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "chrono-node": "^2.9.0"
  }
}
